{
	"Format": "2.9.0",
	"ConfigSchema": {
        "Barn Floor": {
            "AllowValues": "Clean, Cozy",
            "Description": "Choose the interior for your barn.",
            "Default": "Clean",
            "Section": "Indoor Appearance"
        },
        "Coop Floor": {
            "AllowValues": "Clean, Cozy",
            "Description": "Choose the interior for your coop.",
            "Default": "Clean",
            "Section": "Indoor Appearance"
        },
        "Machines": {
			"AllowValues": "Exposed, Hidden, None",
			"Description": "For the Heater, Auto-Grabber, and Auto-Petter, choose to have them exposed, hidden, or not spawn at all. Hidden places them all behind a wall but will still function.",
			"Default": "Exposed",
			"Section": "Indoor Appearance"
        }
    },
	"Changes": [
		{
			"Action": "Load",
			"Target": "Maps/prime_Clean_PrimeBarn",
			"FromFile": "assets/clean_PrimeBarn.tmx"
		},
		{
			"Action": "Load",
			"Target": "Maps/prime_Clean_PrimeCoop",
			"FromFile": "assets/clean_PrimeCoop.tmx"
		},
		{
			"Action": "Load",
			"Target": "Maps/prime_Cozy_PrimeBarn",
			"FromFile": "assets/cozy_PrimeBarn.tmx"
		},
		{
			"Action": "Load",
			"Target": "Maps/prime_Clean_PrimeCoop",
			"FromFile": "assets/cozy_PrimeCoop.tmx"
		},
		{
			"Action": "EditData",
			"Target": "Data/PaintData",
			"Entries": {
				"{{ModId}}_PrimeBarn": "Building/-10 0/Roof/-10 5/Trim/-5 0"
			}
		},
		{
			"Action": "EditData",
			"Target": "Data/PaintData",
			"Entries": {
				"{{ModId}}_PrimeCoop": "Building/-12 0/Roof/-10 5/Trim/-10 5"
		    }
	    },
        {
            "Action": "Include",
            "FromFile": "data/PrimeExposed.json",
            "When":
            {
                "Machines": "Exposed"
            }
        },
        {
            "Action": "Include",
            "FromFile": "data/PrimeHidden.json",
            "When":
            {
                "Machines": "Hidden"
			}
        },
        {
            "Action": "Include",
            "FromFile": "data/PrimeNone.json",
            "When":
            {
                "Machines": "None"
            }
        }
    ]
}
