{
	"Format": "2.9.0",
	"ConfigSchema": {
        "Barn Floor": {
            "AllowValues": "Clean, Cozy",
            "Description": "Choose the interior for your barn.",
            "Default": "Clean",
            "Section": "Indoor Appearance"
        },
        "Coop Floor": {
            "AllowValues": "Clean, Cozy",
            "Description": "Choose the interior for your coop.",
            "Default": "Clean",
            "Section": "Indoor Appearance"
        },
        "Machines": {
			"AllowValues": "Exposed, Hidden, None",
			"Description": "For the Heater, Auto-Grabber, and Auto-Petter, choose to have them exposed, hidden, or not spawn at all. Hidden places them all behind a wall but will still function.",
			"Default": "Exposed",
			"Section": "Indoor Appearance"
        }
    },
	"Changes": [
		{
			"Action": "Load",
			"Target": "Maps/Premium_Clean_PremiumBarn",
			"FromFile": "assets/clean_PremiumBarn.tmx"
		},
		{
			"Action": "Load",
			"Target": "Maps/Premium_Clean_PremiumCoop",
			"FromFile": "assets/clean_PremiumCoop.tmx"
		},
		{
			"Action": "Load",
			"Target": "Maps/Premium_Cozy_PremiumBarn",
			"FromFile": "assets/cozy_PremiumBarn.tmx"
		},
		{
			"Action": "Load",
			"Target": "Maps/Premium_Clean_PremiumCoop",
			"FromFile": "assets/cozy_PremiumCoop.tmx"
		},
		{
			"Action": "EditData",
			"Target": "Data/PaintData",
			"Entries": {
				"{{ModId}}_PremiumBarn": "Building/-10 0/Roof/-10 5/Trim/-5 0"
			}
		},
		{
			"Action": "EditData",
			"Target": "Data/PaintData",
			"Entries": {
				"{{ModId}}_PremiumCoop": "Building/-12 0/Roof/-10 5/Trim/-10 5"
		    }
	    },
        {
            "Action": "Include",
            "FromFile": "data/PremiumExposed.json",
            "When":
            {
                "Machines": "Exposed"
            }
        },
        {
            "Action": "Include",
            "FromFile": "data/PremiumHidden.json",
            "When":
            {
                "Machines": "Hidden"
			}
        },
        {
            "Action": "Include",
            "FromFile": "data/PremiumNone.json",
            "When":
            {
                "Machines": "None"
            }
        }
    ]
}
