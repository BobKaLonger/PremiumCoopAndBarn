        "Target": "Buildings/SVE_PremiumBarn_PaintMask",
        "FromFile": "assets/PaintMask/PremiumBarn_{{season}}_PaintMask.png",
        "When" : {
            "Premium Barn Retexture" : "true"
        }
    }
    ]
}