{
    "Format": "2.9.0",
    "ConfigSchema": {
        "Premium Barn Retexture": {
            "AllowValues": "true, false",
            "Default": "true"
        },
        "Premium Coop Retexture": {
            "AllowValues": "true, false",
            "Default": "true"
        },
        "Premium Barn Roof Style": {
            "AllowValues": "copper, shingles",
            "Default": "copper"
        },
        "Premium Coop Roof Style": {
            "AllowValues": "copper, shingles",
            "Default": "copper"
        },
        "Premium Coop Siding Color": {
            "AllowValues": "green, red",
            "Default": "green"
        } 
},
  "Changes": [
// SVE
    //Premium Barn
	{
        "Action": "EditImage",
	    "PatchMode": "Replace",
        "Target": "Buildings/SVE_PremiumBarn",
        "FromFile": "assets/PremiumBarnCopper_{{Season}}.png",
        "When" : {
            "Premium Barn Retexture" : "true"
	    }
    },
    {
        "Action": "EditImage",
	    "PatchMode": "Overlay",
        "Target": "Buildings/SVE_PremiumBarn",
        "FromFile": "assets/PremiumBarn_ShingleRoof.png",
        "When" : {
            "Premium Barn Roof Style" : "shingles",
            "Season" : "Spring, Summer, Fall"
        }
    },
    {
        "Action": "EditImage",
	    "PatchMode": "Overlay",
        "Target": "Buildings/SVE_PremiumBarn",
        "FromFile": "assets/PremiumBarn_ShingleWinter.png",
        "When" : {
            "Premium Barn Roof Style" : "shingles",
            "Season" : "Winter"
        }
    },
    {
        "Action": "EditImage",
        "Priority": "Late +1",
	    "PatchMode": "Overlay",
        "Target": "Buildings/SVE_PremiumBarn",
        "FromFile": "assets/Overlay_Barn_{{Season}}.png",
        "When" : {
            "Premium Barn Retexture" : "true",
            "Season" : "Spring, Summer, Fall"
	    }
    },
    //Premium Coop
	{
        "Action": "EditImage",
	    "PatchMode": "Replace",
        "Target": "Buildings/SVE_PremiumCoop",
        "FromFile": "assets/PremiumCoopCopper_{{Season}}.png",
        "When" : {
            "Premium Coop Retexture" : "true"
	    }
    },
    {
