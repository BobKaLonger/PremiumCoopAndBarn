        "Action": "EditImage",
        "Priority": "Late +1",
	    "PatchMode": "Overlay",
        "Target": "Buildings/SVE_PremiumCoop",
        "FromFile": "assets/Overlay_Coop_{{Season}}.png",
        "When" : {
            "Premium Coop Retexture" : "true",
            "Season" : "Spring, Summer, Fall"
	    }
