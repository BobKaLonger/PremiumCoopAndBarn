	{
    "Snowcolor": {
        "AllowValues": "vanilla, desaturated",
        "Default": "vanilla",
        "Section": "Sprite Options For Snow",
        "Description": "select vanilla or desatured snow color."
    },
    "OstrichInCoop": {
        "AllowValues": "true, false",
        "Default": "true",
