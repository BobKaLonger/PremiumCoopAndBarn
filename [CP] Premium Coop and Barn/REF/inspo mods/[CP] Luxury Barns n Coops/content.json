        },
        {
            "Name":"night",
            "Value":"2000",
            "When":{"Season":"spring,summer"}
        },
        {
            "Name":"night",
            "Value":"1900",
            "When":{"Season":"fall"}
        },
        {
            "Name":"night",
            "Value":"1800",
            "When":{"Season":"winter"}
